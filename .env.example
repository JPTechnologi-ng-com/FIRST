# Copy this file to .env and fill in your SMTP credentials
# Example using Gmail (requires an App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Example using Mailtrap for safe local email testing:
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_SECURE=false
# SMTP_USER=your-mailtrap-user
# SMTP_PASS=your-mailtrap-pass

# From address shown on the email
FROM_ADDRESS="Clement Stack <hello@yourdomain.com>"
# Where to send contact form messages
TO_ADDRESS=josephclement332@gmail.com

# Optional: set to true to use SSL (465) connections
# SMTP_SECURE=false
